# ─────────────────────────────────────────────
# DISCORD
# ─────────────────────────────────────────────
DISCORD_TOKEN=your_bot_token_here
DISCORD_CLIENT_ID=your_client_id_here
DISCORD_CLIENT_SECRET=your_client_secret_here
DISCORD_GUILD_ID=your_dev_guild_id_here   # optional: deploy commands only here in dev

# ─────────────────────────────────────────────
# DATABASE
# ─────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/discord-sales-bot
REDIS_URL=redis://localhost:6379

# ─────────────────────────────────────────────
# API
# ─────────────────────────────────────────────
API_PORT=4000
API_SECRET_KEY=change_this_to_a_very_long_random_secret
JWT_SECRET=another_very_long_random_secret
JWT_EXPIRES_IN=7d
BCRYPT_ROUNDS=12

# ─────────────────────────────────────────────
# DASHBOARD (OAuth2 redirect)
# ─────────────────────────────────────────────
DASHBOARD_URL=http://localhost:3000
DISCORD_OAUTH_REDIRECT_URI=http://localhost:4000/auth/discord/callback

# ─────────────────────────────────────────────
# PIX
# ─────────────────────────────────────────────
DEFAULT_PIX_KEY=sua_chave_pix_aqui
DEFAULT_PIX_KEY_TYPE=cpf   # cpf | cnpj | email | phone | random
DEFAULT_PIX_MERCHANT_NAME=Sua Loja
DEFAULT_PIX_CITY=Sao Paulo
PAYMENT_EXPIRATION_MINUTES=30

# ─────────────────────────────────────────────
# OCR / ANTI-FRAUDE
# ─────────────────────────────────────────────
TESSERACT_LANG=por
MAX_OCR_ATTEMPTS=3
OCR_CONFIDENCE_THRESHOLD=60

# ─────────────────────────────────────────────
# ENVIRONMENT
# ─────────────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=debug
